<?php
/**
 * 纵横四海 - 地图主页
 */
require_once __DIR__ . '/../inc/functions.php';

$role = requireLogin();

// 航海中检测
if ($role->sail_time > 0) {
    redirect('/sail/index.php');
}

// 处理移动
if (isset($_GET['dir']) && in_array($_GET['dir'], ['n', 's', 'e', 'w'])) {
    $place = $role->getPlace();
    if ($place) {
        $target = (int)$place[$_GET['dir']];
        if ($target > 0) {
            $role->move($target);
            redirect('/map/index.php');
        } else {
            $noExit = true;
        }
    }
}

// 处理回酒店
if (isset($_GET['heal'])) {
    $place = $role->getPlace();
    if ($place && $place['id'] == START_PLACE_ID) {
        $role->fullHeal();
    }
    redirect('/map/index.php');
}

$place = $role->getPlace();
$nearby = $role->getNearby();

if (!$place) {
    $role->move(START_PLACE_ID);
    $place = $role->getPlace();
}

// 获取城市信息
$city = null;
if ($place['city_id']) {
    $city = db()->getOne("SELECT * FROM `map` WHERE `id` = ?", [$place['city_id']]);
}

// 获取城市所有地点
$cityPlaces = [];
if ($city) {
    $cityPlaces = db()->getAll(
        "SELECT * FROM `place` WHERE `city_id` = ? ORDER BY `id`",
        [$city['id']]
    );
}

// 检查是否有怪物
$monsters = [];
if ($place['type'] == 0) {
    $regionId = db()->getVar("SELECT `parent_id` FROM `map` WHERE `id` = ?", [$city['id']]);
    $monsters = db()->getAll(
        "SELECT * FROM `monster` WHERE `region_id` = ? AND `place_id` = 0 ORDER BY `hp`",
        [$regionId]
    );
}

// 进入地图时自动更新收集类任务进度
$role->updateCollectQuests();

// 检查特殊地点
$isDock = ($place['type'] == 1);
$isShop = ($place['id'] == SHOP_PLACE_ID);
$isMarket = ($place['type'] == 2);
$isTavern = ($place['id'] == START_PLACE_ID);
$isInn = ($place['id'] == 1036);
$isBank = ($place['id'] == 1024);
$isCasino = ($place['id'] == 1013);
$isSmith = ($place['id'] == 1031);

// 检查当前地点的NPC
$placeNpcs = db()->getAll("SELECT * FROM `npc` WHERE `place_id` = ? ORDER BY `id`", [$place['id']]);
// 预加载每个NPC的任务数据
$npcQuestCache = [];
foreach ($placeNpcs as $pn) {
    $avail = db()->getAll("SELECT q.id, q.name, q.description, q.level_req, q.require_value, q.reward_exp, q.reward_money, q.reward_item_id, q.reward_item_qty, q.type, q.pre_quest_id
        FROM quest q WHERE q.npc_id = ? AND q.level_req <= ? ORDER BY q.sort_order, q.id", [$pn['id'], $role->level]);
    $availFiltered = [];
    foreach ($avail as $q) {
        $exists = db()->getVar("SELECT COUNT(*) FROM user_quest WHERE user_id = ? AND quest_id = ?", [$role->id, $q['id']]);
        if ($exists > 0) continue;
        if ($q['pre_quest_id'] > 0) {
            $preDone = db()->getVar("SELECT COUNT(*) FROM user_quest WHERE user_id = ? AND quest_id = ? AND status >= 1", [$role->id, $q['pre_quest_id']]);
            if ($preDone == 0) continue;
        }
        $rt = '经验+' . $q['reward_exp'] . ' 铜币+' . $q['reward_money'];
        if ($q['reward_item_id'] > 0) {
            $ri = db()->getOne("SELECT name FROM item WHERE id = ?", [$q['reward_item_id']]);
            if ($ri) $rt .= ' ' . $ri['name'] . '×' . $q['reward_item_qty'];
        }
        $availFiltered[] = ['id'=>$q['id'],'name'=>$q['name'],'desc'=>$q['description'],'lv'=>$q['level_req'],'reward'=>$rt,'req'=>$q['require_value']];
    }
    $active = db()->getAll("SELECT q.id, q.name, q.require_value, uq.progress, uq.status
        FROM quest q JOIN user_quest uq ON q.id = uq.quest_id
        WHERE uq.user_id = ? AND q.npc_id = ? AND uq.status < 2 ORDER BY q.sort_order, q.id", [$role->id, $pn['id']]);
    $npcQuestCache[$pn['id']] = json_encode(['available'=>$availFiltered, 'active'=>$active]);
}

// 检查进行中的任务
$activeQuests = db()->getAll(
    "SELECT q.*, uq.progress, uq.status FROM `quest` q
     JOIN `user_quest` uq ON q.id = uq.quest_id
     WHERE uq.user_id = ? AND uq.status IN (0, 1)",
    [$role->id]
);
$completedQuests = db()->getAll(
    "SELECT COUNT(*) AS cnt FROM `user_quest` WHERE `user_id` = ? AND `status` = 1",
    [$role->id]
);
$claimableCount = $completedQuests[0]['cnt'] ?? 0;

// 到达地点检测任务进度
if (is_array($activeQuests)) {
    foreach ($activeQuests as $aq) {
        if ($aq['type'] == 2 && $aq['target_id'] == $place['id'] && $aq['status'] == 0 && $aq['progress'] < $aq['require_value']) {
            db()->update('user_quest', [
                'progress' => $aq['require_value'],
                'status' => 1,
            ], '`user_id` = ? AND `quest_id` = ?', [$role->id, $aq['id']]);
        }
    }
}

// 获取方向对应地点名称
$dirNames = ['n' => '北', 's' => '南', 'e' => '东', 'w' => '西'];
$dirPlaces = [];
foreach ($dirNames as $dk => $dn) {
    if ($place[$dk] > 0) {
        $dp = db()->getOne("SELECT `name` FROM `place` WHERE `id` = ?", [$place[$dk]]);
        $dirPlaces[$dk] = $dp ? $dp['name'] : '';
    }
}

// 获取在线人数
$onlineCount = db()->getVar("SELECT COUNT(*) FROM `user` WHERE `lastdate` > ? AND `id` != ?", [time() - ONLINE_TIMEOUT, $role->id]);

renderHeader($place['name'] . ' - ' . ($city ? $city['name'] : '未知'));
?>
<!-- 快捷状态栏 -->
<div class="quick-stats">
    <div class="qs-item qs-hp">
        <span class="qs-icon">❤️</span>
        <div class="qs-bar-wrap"><div class="qs-bar qs-hp-bar" style="width:<?php echo $role->hp_max > 0 ? round($role->hp/$role->hp_max*100) : 0; ?>%"></div></div>
        <span class="qs-val"><?php echo $role->hp; ?>/<?php echo $role->hp_max; ?></span>
    </div>
    <div class="qs-item qs-exp">
        <span class="qs-icon">⭐</span>
        <div class="qs-bar-wrap"><div class="qs-bar qs-exp-bar" style="width:<?php echo $role->exp_max > 0 ? round($role->exp/$role->exp_max*100) : 0; ?>%"></div></div>
        <span class="qs-val"><?php echo $role->exp; ?>/<?php echo $role->exp_max; ?></span>
    </div>
    <div class="qs-item qs-money">
        <span class="qs-icon">💰</span>
        <span class="qs-val" id="qsMoneyVal"><?php echo number_format($role->money); ?></span>
    </div>
    <?php if($role->gold > 0): ?>
    <div class="qs-item qs-gold">
        <span class="qs-icon">🪙</span>
        <span class="qs-val"><?php echo $role->gold; ?></span>
    </div>
    <?php endif; ?>
</div>


