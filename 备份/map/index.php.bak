                $hasActive = db()->getVar("SELECT COUNT(*) FROM user_quest uq JOIN quest q ON uq.quest_id=q.id WHERE uq.user_id=? AND q.npc_id=? AND uq.status=0",[$role->id,$pn['id']]);
                $availQuests = db()->getVar("SELECT COUNT(*) FROM quest q WHERE q.npc_id=? AND q.level_req<=? AND q.id NOT IN (SELECT quest_id FROM user_quest WHERE user_id=?) AND (q.pre_quest_id=0 OR q.pre_quest_id IN (SELECT quest_id FROM user_quest WHERE user_id=? AND status>=1))",[$pn['id'],$role->level,$role->id,$role->id]);
                $totalQuests = db()->getVar("SELECT COUNT(*) FROM quest WHERE npc_id=?", [$pn['id']]);
                $doneQuests = db()->getVar("SELECT COUNT(*) FROM user_quest uq JOIN quest q ON uq.quest_id=q.id WHERE uq.user_id=? AND q.npc_id=? AND uq.status=2",[$role->id,$pn['id']]);
                $triggerType = 'idle';
                if($hasReady>0) $triggerType='quest_ready';
                elseif($hasActive>0) $triggerType='quest_active';
                elseif($availQuests>0) $triggerType='quest_available';
                elseif($totalQuests>0&&$doneQuests>=$totalQuests) $triggerType='all_done';
                $nd = db()->getOne("SELECT content FROM npc_dialog WHERE npc_id=? AND trigger_type=? LIMIT 1", [$pn['id'], $triggerType]);
                if($nd) $dynDialog = $nd['content'];
                ?>           data-dialog="<?php echo e($dynDialog); ?>"
           data-npc-type="<?php echo $npcType; ?>"
           data-action="<?php echo $npcAction; ?>"
           data-icon="<?php echo $npcIcon; ?>"
