<script>
document.addEventListener("DOMContentLoaded", function(){
    var grid = document.querySelector("#globalFuncFloat .func-grid");
    if(!grid) return;
<?php if ($claimableCount > 0): ?>
    var questBtn = grid.querySelector("a[href*='/quest/']");
    if(questBtn){
        questBtn.style.position = "relative";
        var badge = document.createElement("span");
        badge.className = "func-badge";
        badge.textContent = "<?php echo $claimableCount; ?>";
        questBtn.appendChild(badge);
    }
<?php endif; ?>
<?php if ($isDock || $isBank || $isSmith || $isTavern || $isInn || ($city && count($cityPlaces) > 0)): ?>
    grid.insertAdjacentHTML("beforeend", '<div class="func-section-divider"></div>');
<?php endif; ?>
<?php if ($isDock): ?>
    grid.insertAdjacentHTML("beforeend", '<a href="/sail/index.php" class="func-btn func-highlight"><span class="func-emoji">⛵</span><span class="func-label">航海</span></a>');
<?php endif; ?>
<?php if ($isBank): ?>
    grid.insertAdjacentHTML("beforeend", '<a href="/bank/index.php" class="func-btn func-highlight"><span class="func-emoji">🏦</span><span class="func-label">银行</span></a>');
<?php endif; ?>
<?php if ($isSmith): ?>
    grid.insertAdjacentHTML("beforeend", '<a href="/smith/index.php" class="func-btn func-highlight"><span class="func-emoji">⚒️</span><span class="func-label">铁匠</span></a>');
<?php endif; ?>

<?php if ($isTavern || $isInn): ?>
    grid.insertAdjacentHTML("beforeend", '<a href="/map/index.php?heal=1" class="func-btn func-success"><span class="func-emoji">🏠</span><span class="func-label">休息</span></a>');
<?php endif; ?>
<?php if ($city && count($cityPlaces) > 0): ?>
    grid.insertAdjacentHTML("beforeend", '<a href="/map/citymap.php" class="func-btn"><span class="func-emoji">🗺️</span><span class="func-label">城内</span></a>');
<?php endif; ?>
});

function showQuestBtn(npcId,questsJson){
    var area=document.getElementById('npcQuestArea');
    if(!area)return;
    var data;
    try{data=JSON.parse(questsJson);}catch(e){return;}
    if(!data||(!data.available.length&&!data.active.length)){area.innerHTML='';return;}
    window._npcQuestData=data;
    window._currentNpcId=npcId;
    var totalCount=data.available.length+data.active.length;
    area.innerHTML='<div style="margin-top:6px;text-align:center;">'
        +'<a onclick="openQuestModal(event)" style="display:inline-block;background:linear-gradient(135deg,#8e44ad,#6c3483);color:#fff;padding:6px 16px;border-radius:6px;font-size:12px;font-weight:600;text-decoration:none;cursor:pointer;">📜 任务('+totalCount+')</a>'
        +'</div>';
}
function openQuestModal(evt){
    if(evt){evt.preventDefault();evt.stopPropagation();}
    var data=window._npcQuestData;
    var npcId=window._currentNpcId;
    if(!data){return;}
    var npcName=data.npc_name||'NPC';
    var h='<div class="modal-header">'
        +'<div class="modal-avatar" style="background:rgba(142,68,173,0.15);border:2px solid #8e44ad;">📜</div>'
        +'<div><div class="modal-title" style="color:#8e44ad;">'+npcName+' · 任务</div>'
        +'<div class="modal-subtitle">任务接取与奖励领取</div></div></div>'
        +'<div class="modal-body" id="questModalBody">';
    if(data.available.length){
        h+='<div style="font-size:12px;font-weight:600;color:#27ae60;margin-bottom:6px;">📋 可接任务</div>';
        data.available.forEach(function(q){
            h+='<div style="background:rgba(39,174,96,0.06);border:1px solid rgba(39,174,96,0.15);border-radius:8px;padding:8px 10px;margin-bottom:6px;">'
                +'<div style="display:flex;justify-content:space-between;align-items:center;">'
                +'<span style="font-size:13px;font-weight:600;">'+q.name+'</span>'
                +'<span style="font-size:10px;color:#95a5a6;">Lv.'+(q.lv||'?')+'</span></div>'
                +'<div style="font-size:11px;color:#7f8c8d;margin:3px 0;">'+(q.desc||'')+'</div>'
                +'<div style="font-size:10px;color:#e67e22;">🎁 '+(q.reward||'')+'</div>'
                +'<button onclick="acceptQuest('+q.id+','+npcId+')" style="margin-top:6px;background:linear-gradient(135deg,#27ae60,#1e8449);color:#fff;border:none;padding:6px 16px;border-radius:6px;font-size:12px;cursor:pointer;width:100%;">✅ 接取任务</button>'
                +'</div>';
        });
    }
    if(data.active.length){
        h+='<div style="font-size:12px;font-weight:600;color:#e2b714;margin-bottom:6px;'+(data.available.length?'margin-top:10px;':'')+'">🔄 进行中</div>';
        data.active.forEach(function(q){
            var done=q.status==1;
            var pct=Math.min(100,Math.round(q.progress/Math.max(1,q.require_value)*100));
            h+='<div style="background:'+(done?'rgba(39,174,96,0.08)':'rgba(226,183,20,0.06)')+';border:1px solid '+(done?'rgba(39,174,96,0.2)':'rgba(226,183,20,0.12)')+';border-radius:8px;padding:8px 10px;margin-bottom:6px;">'
                +'<div style="display:flex;justify-content:space-between;align-items:center;">'
                +'<span style="font-size:13px;">'+(done?'✅':'🔄')+' '+q.name+'</span>'
                +'<span style="font-size:11px;color:'+(done?'#27ae60':'#e2b714')+';">'+(done?'已完成':q.progress+'/'+q.require_value)+'</span></div>';
            if(!done){
                h+='<div style="background:#ecf0f1;border-radius:4px;height:6px;margin-top:6px;overflow:hidden;"><div style="background:linear-gradient(90deg,#e2b714,#f39c12);height:100%;width:'+pct+'%;border-radius:4px;"></div></div>';
            }
            if(done){
                h+='<div style="margin-top:6px;text-align:center;color:#27ae60;font-size:12px;font-weight:600;">✅ 可在任务页面领取奖励</div>';
            }
            h+='</div>';
        });
    }
    h+='</div><div class="modal-footer">'
        +'<a href="javascript:closeQuestModal()" class="modal-btn modal-btn-close">关闭</a>'
        +'</div>';
    openModal2(h);
}
function acceptQuest(qid,npcId){
    var btn=event.target;btn.disabled=true;btn.textContent='接取中...';
    var fd=new FormData();fd.append('accept_quest',qid);
    fetch('/npc/action.php',{method:'POST',body:fd})
        .then(function(r){return r.json();})
        .then(function(resp){
            openQuestModal(new Event('click'));
        });
}
function claimQuest(qid,npcId){
    var btn=event.target;btn.disabled=true;btn.textContent='领取中...';
    var fd=new FormData();fd.append('claim_quest',qid);
    fetch('/npc/action.php',{method:'POST',body:fd})
        .then(function(r){return r.json();})
        .then(function(resp){
            openQuestModal(new Event('click'));
        });
}
</script>


<!-- 弹窗容器 -->
<div class="modal-overlay" id="entityModal" onclick="if(event.target===this)closeModal()">
    <div class="modal-card" id="modalCard"></div>
</div>

<script>
function openModal(html){
    var m=document.getElementById('entityModal');
    document.getElementById('modalCard').innerHTML=html;
    m.classList.add('active');
    document.body.style.overflow='hidden';
}
function closeModal(){
    var m=document.getElementById('entityModal');
    m.classList.remove('active');
    document.body.style.overflow='';
}
function openModal2(html){
    var m=document.getElementById('entityModal2');
    if(!m){
        m=document.createElement('div');
        m.id='entityModal2';
        m.style.cssText='position:fixed;inset:0;z-index:2001;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);opacity:0;pointer-events:none;transition:opacity 0.2s;';
        var c=document.createElement('div');
        c.className='modal-card';
        c.style.cssText='max-width:460px;width:92%;max-height:82vh;overflow-y:auto;box-shadow:0 10px 40px rgba(0,0,0,0.5);';
        m.appendChild(c);
        document.body.appendChild(m);
    }
    m.querySelector('.modal-card').innerHTML=html;
    requestAnimationFrame(function(){m.style.opacity='1';m.style.pointerEvents='auto';});
}
function closeQuestModal(){
    var m=document.getElementById('entityModal2');
    if(m){m.style.opacity='0';m.style.pointerEvents='none';}
}

// ===== NPC弹窗交互函数 =====
function updateMapMoney(money){
    var el=document.getElementById('qsMoneyVal');
    if(el) el.textContent=parseInt(money).toLocaleString();
}
function npcAction(npcId,type,name,action){
    switch(type){
        case 'shop': loadShopModal(npcId,name); break;
        case 'craft': loadSmithModal(npcId,name); break;
        case 'bank': loadBankModal(npcId,name); break;
        case 'danger': loadCasinoModal(npcId,name); break;
        case 'talk':
        case 'quest': loadChatModal(npcId,name); break;
    }
}

// ===== 商店弹窗 =====
function loadShopModal(npcId,name){
    var html='<div class="modal-header"><div class="modal-avatar" style="background:rgba(226,183,20,0.12);border:2px solid #e2b714">🏪</div>'
        +'<div><div class="modal-title" style="color:#e2b714;">'+name+' · 商店</div>'
        +'<div class="modal-subtitle" id="shopMoney">💰 加载中...</div></div></div>'
        +'<div class="modal-body" id="shopBody"><div style="text-align:center;padding:20px;color:#8a7a5a;">加载中...</div></div>'
        +'<div class="modal-footer"><a href="javascript:closeModal()" class="modal-btn modal-btn-close">返回</a></div>';
    openModal(html);
    fetch('/api/npc_shop.php?npc='+npcId).then(function(r){return r.json();}).then(function(data){
        document.getElementById('shopMoney').textContent='💰 铜币：'+parseInt(data.money).toLocaleString();
        updateMapMoney(data.money);
        var body=document.getElementById('shopBody');
        if(!data.items||data.items.length===0){body.innerHTML='<div style="text-align:center;padding:20px;color:#8a7a5a;">这个商人暂时没有货物出售</div>';return;}
        var h='<div style="max-height:50vh;overflow-y:auto;scrollbar-width:none;">';
        data.items.forEach(function(item){
            var icon='📦';if(item.type==='weapon')icon='⚔️';else if(item.type==='armor')icon='🛡️';else if(item.type==='consumable')icon='🌊';
            var lv=item.level_req>1?' <span style="color:#95a5a6;font-size:10px;">Lv.'+item.level_req+'</span>':'';
            var stats='';if(item.atk>0)stats+=' ⚔️+'+item.atk;if(item.def_val>0)stats+=' 🛡️+'+item.def_val;if(item.hp>0)stats+=' ❤️回'+item.hp+'HP';
            h+='<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:8px;margin-bottom:4px;">'
                +'<div style="flex:1;min-width:0;">'
                +'<div style="font-size:12px;color:#f5e6c8;font-weight:600;">'+icon+' '+item.name+lv+'</div>'
                +'<div style="font-size:10px;color:#8a7a5a;margin-top:2px;">'+(item.description||'')+stats+'</div>'
                +'<div style="font-size:11px;color:#e67e22;font-weight:600;margin-top:2px;">'+parseInt(item.price_buy).toLocaleString()+' 铜</div>'
                +'</div>'
                +'<div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;">'
                +'<div style="display:inline-flex;border:1px solid rgba(226,183,20,0.3);border-radius:4px;overflow:hidden;">'
                +'<button type="button" onclick="var i=this.parentElement.querySelector(\'input\');i.value=Math.max(1,parseInt(i.value||1)-1)" style="background:rgba(255,255,255,0.05);color:#f5e6c8;border:none;width:24px;height:24px;font-size:12px;cursor:pointer;">-</button>'
                +'<input type="number" value="1" min="1" max="99" class="shop-qty-'+item.id+'" style="width:32px;height:24px;border:none;border-left:1px solid rgba(226,183,20,0.3);border-right:1px solid rgba(226,183,20,0.3);text-align:center;font-size:11px;background:rgba(0,0,0,0.2);color:#f5e6c8;outline:none;-moz-appearance:textfield;">'
                +'<button type="button" onclick="var i=this.parentElement.querySelector(\'input\');i.value=Math.min(99,parseInt(i.value||1)+1)" style="background:rgba(255,255,255,0.05);color:#f5e6c8;border:none;width:24px;height:24px;font-size:12px;cursor:pointer;">+</button>'
                +'</div>'
                +'<button onclick="shopBuy('+item.id+','+npcId+',this)" style="background:rgba(39,174,96,0.15);border:1px solid rgba(39,174,96,0.3);color:#27ae60;padding:4px 12px;font-size:11px;border-radius:4px;cursor:pointer;">购买</button>'
                +'</div></div>';
        });
        h+='</div>';body.innerHTML=h;
    });
}
function shopBuy(itemId,npcId,btn){
    var card=btn.closest('div[style*="border-radius:8px"]');
    var qty=parseInt(document.querySelector('.shop-qty-'+itemId).value)||1;
    btn.disabled=true;btn.textContent='购买中...';
    var fd=new FormData();fd.append('buy_id',itemId);fd.append('qty',qty);
    fetch('/api/npc_shop.php?npc='+npcId,{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        if(data.ok){document.getElementById('shopMoney').textContent='💰 铜币：'+parseInt(data.money).toLocaleString();updateMapMoney(data.money);}
        var rhtml='<div style="text-align:center;padding:16px;"><div style="font-size:36px;margin-bottom:8px;">'+(data.ok?'✅':'❌')+'</div><div style="font-size:13px;color:'+(data.ok?'#27ae60':'#ff6b6b')+';">'+data.msg+'</div></div><div class="modal-footer"><a href="javascript:closeQuestModal()" class="modal-btn modal-btn-close">确定</a></div>';
        openModal2(rhtml);
    });
}

// ===== 铁匠铺弹窗 =====
function loadSmithModal(npcId,name){
    var html='<div class="modal-header"><div class="modal-avatar" style="background:rgba(230,126,34,0.12);border:2px solid #e67e22">⚒️</div>'
        +'<div><div class="modal-title" style="color:#e67e22;">'+name+' · 铁匠铺</div>'
        +'<div class="modal-subtitle" id="smithMoney">💰 加载中...</div></div></div>'
        +'<div class="modal-body" id="smithBody"><div style="text-align:center;padding:20px;color:#8a7a5a;">加载中...</div></div>'
        +'<div class="modal-footer"><a href="javascript:closeModal()" class="modal-btn modal-btn-close">返回</a></div>';
    openModal(html);
    fetch('/api/npc_smith.php').then(function(r){return r.json();}).then(function(data){
        document.getElementById('smithMoney').textContent='💰 铜币：'+parseInt(data.money).toLocaleString();
        updateMapMoney(data.money);
        var body=document.getElementById('smithBody');
        var rules='<div style="font-size:10px;color:#c4a87c;padding:4px 8px;background:rgba(230,126,34,0.06);border:1px solid rgba(230,126,34,0.15);border-radius:6px;margin-bottom:6px;">'
            +'+1~5成功率<span style="color:#27ae60;">90%</span> · +6~8<span style="color:#e67e22;">70%</span> · +9~10<span style="color:#ff6b6b;">30%</span> · ⚠️+7以上失败<span style="color:#ff6b6b;">降级</span> · 💰费用=(等级+1)×200</div>';
        if(!data.items||data.items.length===0){body.innerHTML=rules+'<div style="text-align:center;padding:20px;color:#8a7a5a;">背包中没有可强化的装备</div>';return;}
        var h=rules+'<div style="max-height:50vh;overflow-y:auto;scrollbar-width:none;">';
        data.items.forEach(function(item){
            var icon=item.subtype==='weapon'?'🗡️':'🛡️';
            var el=item.enhance_level;
            var elTag=el>0?'<span style="color:'+item.color+';font-weight:bold;">+'+el+'</span>':'';
            var statsHtml='';
            if(item.atk>0)statsHtml+='⚔️'+item.atk+'→'+item.eff_atk+' ';
            if(item.def_val>0)statsHtml+='🛡️'+item.def_val+'→'+item.eff_def;
            var actionHtml='';
            if(item.is_max){
                actionHtml='<span style="color:#e2b714;font-size:11px;font-weight:bold;">👑 已满级</span>';
            }else{
                var rateColor=item.rate>=70?'#27ae60':'#ff6b6b';
                actionHtml='<div style="font-size:10px;color:#c4a87c;margin-top:2px;">💰'+item.cost+'铜 · 成功率<span style="color:'+rateColor+';">'+item.rate+'%</span></div>'
                    +'<button onclick="smithEnhance('+item.inv_id+',this,'+item.cost+',\''+item.name.replace(/'/g,"\\'")+' '+elTag+'\')" style="background:rgba(230,126,34,0.15);border:1px solid rgba(230,126,34,0.3);color:#e67e22;padding:4px 12px;font-size:11px;border-radius:4px;cursor:pointer;margin-top:4px;">⚒️ 强化</button>';
            }
            h+='<div style="padding:6px 10px;background:rgba(255,255,255,0.03);border:1px solid rgba('+hexToRgb(item.color)+',0.25);border-radius:8px;margin-bottom:4px;">'
                +'<div style="display:flex;justify-content:space-between;align-items:center;">'
                +'<span style="font-size:12px;color:#f5e6c8;font-weight:600;">'+icon+' '+item.name+' '+elTag+'</span>'
                +'<span style="font-size:10px;color:#c4a87c;">'+statsHtml+'</span></div>'
                +actionHtml+'</div>';
        });
        h+='</div>';body.innerHTML=h;
    });
}
function smithEnhance(invId,btn,cost,nameStr){
    if(!confirm('确定要强化吗？费用'+cost+'铜'))return;
    btn.disabled=true;btn.textContent='强化中...';
    var fd=new FormData();fd.append('enhance_id',invId);
    fetch('/api/npc_smith.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        if(data.money){document.getElementById('smithMoney').textContent='💰 铜币：'+parseInt(data.money).toLocaleString();updateMapMoney(data.money);}
        var rhtml='<div style="text-align:center;padding:16px;"><div style="font-size:36px;margin-bottom:8px;">'+(data.ok?'✨':'😈')+'</div><div style="font-size:13px;color:'+(data.ok?'#27ae60':'#ff6b6b')+';">'+data.msg+'</div></div>'
            +'<div class="modal-footer"><a href="javascript:closeQuestModal();setTimeout(function(){loadSmithModal(0,\'铁匠铺\')},100)" class="modal-btn modal-btn-close">确定</a></div>';
        openModal2(rhtml);
    });
}
function hexToRgb(hex){var r=parseInt(hex.slice(1,3),16);var g=parseInt(hex.slice(3,5),16);var b=parseInt(hex.slice(5,7),16);return r+','+g+','+b;}

// ===== 银行弹窗 =====
function loadBankModal(npcId,name){
    var html='<div class="modal-header"><div class="modal-avatar" style="background:rgba(39,174,96,0.12);border:2px solid #27ae60">🏦</div>'
        +'<div><div class="modal-title" style="color:#27ae60;">'+name+' · 银行</div>'
        +'<div class="modal-subtitle">最安全的资金保管</div></div></div>'
        +'<div class="modal-body" id="bankBody"><div style="text-align:center;padding:20px;color:#8a7a5a;">加载中...</div></div>'
        +'<div class="modal-footer"><a href="javascript:closeModal()" class="modal-btn modal-btn-close">返回</a></div>';
    openModal(html);
    fetch('/api/npc_bank.php').then(function(r){return r.json();}).then(function(data){
        updateMapMoney(data.money);renderBankContent(data);
    });
}
function renderBankContent(data){
    var body=document.getElementById('bankBody');
    if(!body){return;}
    var total=parseInt(data.money)+parseInt(data.bank_money);
    var money=parseInt(data.money),bm=parseInt(data.bank_money);
    var h='';
    h+='<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;text-align:center;padding:6px 8px;background:rgba(255,255,255,0.03);border-radius:8px;margin-bottom:8px;">'
        +'<div><div style="font-size:10px;color:#c4a87c;">携带</div><div style="font-size:13px;color:#e2b714;font-weight:bold;">'+money.toLocaleString()+'</div></div>'
        +'<div><div style="font-size:10px;color:#c4a87c;">存款</div><div style="font-size:13px;color:#27ae60;font-weight:bold;">'+bm.toLocaleString()+'</div></div>'
        +'<div><div style="font-size:10px;color:#c4a87c;">总资产</div><div style="font-size:14px;color:#e2b714;font-weight:bold;">'+total.toLocaleString()+'</div></div></div>';
    h+='<div style="padding:6px 8px;background:rgba(255,255,255,0.03);border-radius:8px;margin-bottom:6px;">'
        +'<div style="font-size:11px;font-weight:600;color:#27ae60;margin-bottom:4px;">💰 存款</div>'
        +'<div style="display:flex;gap:4px;"><input type="number" id="bankDepositAmt" min="1" placeholder="金额" style="flex:1;padding:6px 8px;background:rgba(0,0,0,0.2);border:1px solid rgba(226,183,20,0.2);border-radius:4px;color:#f5e6c8;font-size:12px;outline:none;">'
        +'<button onclick="bankAction(\'deposit\')" style="background:rgba(39,174,96,0.15);border:1px solid rgba(39,174,96,0.3);color:#27ae60;padding:6px 14px;font-size:12px;border-radius:4px;cursor:pointer;">存入</button></div>'
        +'<div style="display:flex;gap:4px;margin-top:4px;">'
        +'<button onclick="bankQuick(\'deposit\',Math.floor('+money+'*0.5))" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">存50%</button>'
        +'<button onclick="bankQuick(\'deposit\','+money+')" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">全存</button>'
        +'</div></div>';
    h+='<div style="padding:6px 8px;background:rgba(255,255,255,0.03);border-radius:8px;margin-bottom:6px;">'
        +'<div style="font-size:11px;font-weight:600;color:#e2b714;margin-bottom:4px;">💴 取款</div>'
        +'<div style="display:flex;gap:4px;"><input type="number" id="bankWithdrawAmt" min="1" placeholder="金额" style="flex:1;padding:6px 8px;background:rgba(0,0,0,0.2);border:1px solid rgba(226,183,20,0.2);border-radius:4px;color:#f5e6c8;font-size:12px;outline:none;">'
        +'<button onclick="bankAction(\'withdraw\')" style="background:rgba(226,183,20,0.15);border:1px solid rgba(226,183,20,0.3);color:#e2b714;padding:6px 14px;font-size:12px;border-radius:4px;cursor:pointer;">取出</button></div>'
        +'<div style="display:flex;gap:4px;margin-top:4px;">'
        +'<button onclick="bankQuick(\'withdraw\',Math.floor('+bm+'*0.5))" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">取50%</button>'
        +'<button onclick="bankQuick(\'withdraw\','+bm+')" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">全取</button>'
        +'</div></div>';
    if(data.logs&&data.logs.length>0){
        h+='<div style="padding:6px 8px;background:rgba(255,255,255,0.03);border-radius:8px;">'
            +'<div style="font-size:11px;font-weight:600;color:#c4a87c;margin-bottom:4px;">📋 最近交易</div>';
        data.logs.forEach(function(log){
            var t=log.type==0?'📥 存入':'📤 取出';
            var amt=parseInt(log.amount)||0;
            var clr=log.type==0?'#ff6b6b':'#27ae60';
            var sign=log.type==0?'-':'+';
            var d=new Date(parseInt(log.created_at)*1000);
            var ds=('0'+(d.getMonth()+1)).slice(-2)+'/'+('0'+d.getDate()).slice(-2)+' '+('0'+d.getHours()).slice(-2)+':'+('0'+d.getMinutes()).slice(-2);
            h+='<div style="display:flex;justify-content:space-between;padding:3px 0;font-size:11px;">'
                +'<span>'+t+'</span>'
                +'<span style="color:'+clr+';">'+sign+amt.toLocaleString()+' <span style="color:#666;font-size:9px;">'+ds+'</span></span></div>';
        });
        h+='</div>';
    }
    h+='<div style="padding:4px 8px;background:rgba(52,152,219,0.06);border:1px solid rgba(52,152,219,0.15);border-radius:6px;margin-top:6px;">'
        +'<div style="font-size:10px;color:#3498db;">💡 战斗失败损失5%携带铜币，建议多余铜币存入银行</div></div>';
    body.innerHTML=h;
}
function bankAction(action){
    var inputId=action==='deposit'?'bankDepositAmt':'bankWithdrawAmt';
    var amount=parseInt(document.getElementById(inputId).value)||0;
    if(amount<=0)return;
    var fd=new FormData();fd.append('action',action);fd.append('amount',amount);
    fetch('/api/npc_bank.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        updateMapMoney(data.money);renderBankContent(data);
        var rhtml='<div style="text-align:center;padding:16px;"><div style="font-size:36px;margin-bottom:8px;">'+(data.ok?'✅':'❌')+'</div><div style="font-size:13px;color:'+(data.ok?'#27ae60':'#ff6b6b')+';">'+data.msg+'</div></div><div class="modal-footer"><a href="javascript:closeQuestModal()" class="modal-btn modal-btn-close">确定</a></div>';
        openModal2(rhtml);
    });
}
function bankQuick(action,amount){
    if(amount<=0)return;
    var fd=new FormData();fd.append('action',action);fd.append('amount',amount);
    fetch('/api/npc_bank.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        updateMapMoney(data.money);renderBankContent(data);
    });
}

// ===== 赌场弹窗 =====
function loadCasinoModal(npcId,name){
    var html='<div class="modal-header"><div class="modal-avatar" style="background:rgba(231,76,60,0.12);border:2px solid #e74c3c">🎰</div>'
        +'<div><div class="modal-title" style="color:#e74c3c;">'+name+' · 赌场</div>'
        +'<div class="modal-subtitle" id="casinoInfo">加载中...</div></div></div>'
        +'<div class="modal-body" id="casinoBody"><div style="text-align:center;padding:20px;color:#8a7a5a;">加载中...</div></div>'
        +'<div class="modal-footer"><a href="javascript:closeModal()" class="modal-btn modal-btn-close">返回</a></div>';
    openModal(html);
    fetch('/api/npc_casino.php').then(function(r){return r.json();}).then(function(data){
        document.getElementById('casinoInfo').textContent='💰 铜币：'+parseInt(data.money).toLocaleString()+' · 限额：'+parseInt(data.limit).toLocaleString();
        updateMapMoney(data.money);
        renderCasinoGame(data);
    });
}
var currentCasinoChoice='';
function renderCasinoGame(data){
    currentCasinoChoice='';
    var body=document.getElementById('casinoBody');
    var maxBet=Math.min(parseInt(data.money),parseInt(data.limit));
    var h='<div style="font-size:10px;color:#c4a87c;margin-bottom:8px;">🎲 两个骰子 ⚬ 小(2~6) ⚬ 大(7~12) · 猜对赢双倍</div>';
    h+='<div style="display:flex;gap:6px;margin-bottom:8px;">'
        +'<div id="cBtnBig" onclick="pickCasinoChoice(\'big\')" style="flex:1;padding:10px 0;text-align:center;border-radius:8px;font-size:15px;font-weight:bold;cursor:pointer;opacity:0.5;transition:all 0.2s;background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff;border:3px solid transparent;">⚫ 大(7-12)</div>'
        +'<div id="cBtnSmall" onclick="pickCasinoChoice(\'small\')" style="flex:1;padding:10px 0;text-align:center;border-radius:8px;font-size:15px;font-weight:bold;cursor:pointer;opacity:0.5;transition:all 0.2s;background:linear-gradient(135deg,#3498db,#2980b9);color:#fff;border:3px solid transparent;">⚫ 小(2-6)</div></div>';
    h+='<div style="display:flex;gap:4px;margin-bottom:6px;">'
        +'<input type="number" id="casinoBetAmt" min="1" max="'+maxBet+'" placeholder="下注金额" style="flex:1;padding:6px 8px;background:rgba(0,0,0,0.2);border:1px solid rgba(226,183,20,0.2);border-radius:4px;color:#f5e6c8;font-size:12px;outline:none;">'
        +'<button onclick="casinoBet()" style="background:rgba(39,174,96,0.15);border:1px solid rgba(39,174,96,0.3);color:#27ae60;padding:6px 14px;font-size:12px;border-radius:4px;cursor:pointer;">🎲 下注</button></div>';
    h+='<div style="display:flex;gap:4px;">'
        +'<button onclick="casinoQuick(100)" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">⚡ 100</button>'
        +'<button onclick="casinoQuick(500)" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">⚡ 500</button>'
        +'<button onclick="casinoQuick('+Math.min(1000,maxBet)+')" style="flex:1;padding:4px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:4px;color:#c4a87c;font-size:10px;cursor:pointer;">⚡ 全押</button></div>';
    h+='<div id="casinoResult" style="margin-top:8px;"></div>';
    body.innerHTML=h;
}
function pickCasinoChoice(c){
    currentCasinoChoice=c;
    var big=document.getElementById('cBtnBig'),small=document.getElementById('cBtnSmall');
    big.style.opacity=c==='big'?'1':'0.5';big.style.borderColor=c==='big'?'#ff6b6b':'transparent';
    big.style.boxShadow=c==='big'?'0 0 15px rgba(231,76,60,0.4)':'none';
    small.style.opacity=c==='small'?'1':'0.5';small.style.borderColor=c==='small'?'#5dade2':'transparent';
    small.style.boxShadow=c==='small'?'0 0 15px rgba(52,152,219,0.4)':'none';
}
function casinoQuick(amount){
    if(!currentCasinoChoice)pickCasinoChoice('big');
    document.getElementById('casinoBetAmt').value=amount;
    casinoBet();
}
function casinoBet(){
    if(!currentCasinoChoice){
        openModal2('<div style="text-align:center;padding:12px;color:#e67e22;font-size:13px;">⚠️ 请先选择大或小</div><div class="modal-footer"><a href="javascript:closeQuestModal()" class="modal-btn modal-btn-close">确定</a></div>');
        return;
    }
    var amount=parseInt(document.getElementById('casinoBetAmt').value)||0;
    if(amount<=0)return;
    var fd=new FormData();fd.append('bet',amount);fd.append('choice',currentCasinoChoice);
    fetch('/api/npc_casino.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        if(data.ok&&data.dice1){
            document.getElementById('casinoInfo').textContent='💰 铜币：'+parseInt(data.money).toLocaleString()+' · 限额：'+parseInt(data.limit).toLocaleString();
            updateMapMoney(data.money);
            var resultDiv=document.getElementById('casinoResult');
            var winColor=data.isWin?'#27ae60':'#e74c3c';
            resultDiv.innerHTML='<div style="text-align:center;padding:10px;background:rgba('+hexToRgb(winColor)+',0.08);border:1px solid rgba('+hexToRgb(winColor)+',0.2);border-radius:8px;">'
                +'<div style="font-size:36px;">'+data.dice1_face+' + '+data.dice2_face+' = <span style="font-size:22px;color:#e2b714;font-weight:bold;">'+data.total+'</span></div>'
                +'<div style="font-size:13px;margin-top:4px;color:#c4a87c;">'
                +'🔵 '+(data.isBig?'大':'小')+' · 你选了'+(data.choice==='big'?'大':'小')
                +(data.isWin?' <span style="color:#27ae60;">→ 猜对了！</span>':' <span style="color:#ff6b6b;">→ 猜错了</span>')
                +'</div></div>';
        }else{
            openModal2('<div style="text-align:center;padding:12px;color:#ff6b6b;font-size:13px;">❌ '+data.msg+'</div><div class="modal-footer"><a href="javascript:closeQuestModal()" class="modal-btn modal-btn-close">确定</a></div>');
        }
    });
}

// ===== NPC对话弹窗 =====
function loadChatModal(npcId,name){
    var html='<div class="modal-header"><div class="modal-avatar" style="background:rgba(52,152,219,0.12);border:2px solid #3498db">💬</div>'
        +'<div><div class="modal-title" style="color:#3498db;">'+name+'</div>'
        +'<div class="modal-subtitle">NPC对话</div></div></div>'
        +'<div class="modal-body" id="chatBody"><div style="text-align:center;padding:20px;color:#8a7a5a;">加载中...</div></div>'
        +'<div class="modal-footer"><a href="javascript:closeModal()" class="modal-btn modal-btn-close">关闭</a></div>';
    openModal(html);
    fetch('/api/npc_chat.php?npc='+npcId).then(function(r){return r.json();}).then(function(data){
        if(!data.ok){document.getElementById('chatBody').innerHTML='<div style="color:#ff6b6b;">'+data.msg+'</div>';return;}
        renderChatContent(data,npcId,name);
    });
}
function renderChatContent(data,npcId,name){
    var body=document.getElementById('chatBody');
    var h='<div class="modal-dialog" id="chatDialogArea">\u300c'+data.dialog+'\u300d</div>';
    if(data.active_quests&&data.active_quests.length>0){
        var hasClaimable=false;
        data.active_quests.forEach(function(q){if(q.status==1)hasClaimable=true;});
        if(hasClaimable){
            h+='<div style="font-size:11px;font-weight:600;color:#27ae60;margin-bottom:4px;">🎉 可领取奖励</div>';
            data.active_quests.forEach(function(q){
                if(q.status!=1)return;
                h+='<div style="background:rgba(39,174,96,0.08);border:1px solid rgba(39,174,96,0.2);border-radius:8px;padding:6px 8px;margin-bottom:4px;">'
                    +'<div style="display:flex;justify-content:space-between;"><span style="font-size:12px;font-weight:600;">✅ '+q.name+'</span></div>'
                    +'<button onclick="questClaim('+q.id+','+npcId+',\''+name.replace(/'/g,"\\'")+'\')" style="background:linear-gradient(135deg,#27ae60,#1e8449);border:none;color:#fff;padding:4px 12px;font-size:11px;border-radius:4px;cursor:pointer;width:100%;margin-top:4px;">🎁 领取奖励</button></div>';
            });
        }
        var inProgress=data.active_quests.filter(function(q){return q.status==0;});
        if(inProgress.length>0){
            h+='<div style="font-size:11px;font-weight:600;color:#e2b714;margin-bottom:4px;margin-top:6px;">🔄 进行中</div>';
            inProgress.forEach(function(q){
                var pct=Math.min(100,Math.round(parseInt(q.progress)/Math.max(1,parseInt(q.require_value))*100));
                h+='<div style="background:rgba(226,183,20,0.06);border:1px solid rgba(226,183,20,0.12);border-radius:8px;padding:6px 8px;margin-bottom:4px;">'
                    +'<div style="display:flex;justify-content:space-between;font-size:12px;"><span>🔄 '+q.name+'</span><span style="color:#e2b714;">'+q.progress+'/'+q.require_value+'</span></div>'
                    +'<div style="background:rgba(255,255,255,0.06);border-radius:4px;height:5px;margin-top:4px;overflow:hidden;"><div style="background:linear-gradient(90deg,#e2b714,#f39c12);height:100%;width:'+pct+'%;border-radius:4px;"></div></div></div>';
            });
        }
    }
    if(data.available_quests&&data.available_quests.length>0){
        h+='<div style="font-size:11px;font-weight:600;color:#3498db;margin-bottom:4px;margin-top:6px;">📋 可接任务</div>';
        data.available_quests.forEach(function(q){
            h+='<div style="background:rgba(52,152,219,0.06);border:1px solid rgba(52,152,219,0.15);border-radius:8px;padding:6px 8px;margin-bottom:4px;">'
                +'<div style="display:flex;justify-content:space-between;"><span style="font-size:12px;font-weight:600;">📜 '+q.name+'</span><span style="font-size:10px;color:#95a5a6;">Lv.'+q.level_req+'</span></div>'
                +'<div style="font-size:10px;color:#7f8c8d;margin-top:2px;">'+(q.desc||'')+'</div>'
                +'<div style="font-size:10px;color:#e67e22;margin-top:2px;">🎁 '+(q.reward||'')+'</div>'
                +'<button onclick="questAccept('+q.id+','+npcId+',\''+name.replace(/'/g,"\\'")+'\')" style="background:linear-gradient(135deg,#3498db,#2980b9);border:none;color:#fff;padding:4px 12px;font-size:11px;border-radius:4px;cursor:pointer;width:100%;margin-top:4px;">✅ 接取任务</button></div>';
        });
    }
    if(data.chat_topics&&data.chat_topics.length>0){
        // 话题按钮区域
        h+='<div style="margin-top:8px;padding-top:6px;border-top:1px solid rgba(255,255,255,0.05);">';
        h+='<div style="font-size:11px;color:#8a7a5a;margin-bottom:5px;">💬 闲聊话题</div>';
        h+='<div style="display:flex;flex-wrap:wrap;gap:4px;" id="chatTopicBtns_'+npcId+'>';
        data.chat_topics.forEach(function(ct,i){
            var title=ct.text.length>10?ct.text.substring(0,10)+'…':ct.text;
            h+='<span onclick="switchChatTopic('+npcId+','+i+')" class="chat-topic-btn" data-idx="'+i+'" data-text="'+ct.text.replace(/"/g,'&quot;')+'" style="font-size:10px;padding:2px 6px;border-radius:4px;background:rgba(52,152,219,0.1);border:1px solid rgba(52,152,219,0.2);color:#8a7a5a;cursor:pointer;">'+title+'</span>';
        });
        h+='</div></div>';
        // 将话题数据存到全局
        window['_chatTopics_'+npcId]=data.chat_topics;
    }
    // 显示默认随机选中的闲聊
    if(data.default_chat){
        document.getElementById('chatDialogArea').innerHTML='<div style="font-size:11px;color:#a09080;margin-top:6px;padding:4px 8px;background:rgba(255,255,255,0.03);border-radius:6px;">💬 '+data.default_chat.text+'</div>';
    }
    body.innerHTML=h;
}
function questAccept(questId,npcId,name){
    var fd=new FormData();fd.append('action','accept');fd.append('quest_id',questId);fd.append('npc_id',npcId);
    fetch('/api/action_quest.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        loadChatModal(npcId,name);
    });
}

function switchChatTopic(npcId,idx){
    var topics=window['_chatTopics_'+npcId];
    if(!topics||!topics[idx])return;
    var area=document.getElementById('chatDialogArea');
    if(area)area.innerHTML='<div style="font-size:11px;color:#a09080;margin-top:6px;padding:4px 8px;background:rgba(255,255,255,0.03);border-radius:6px;">💬 '+topics[idx].text+'</div>';
    // 高亮当前选中
    var btns=document.querySelectorAll('#chatTopicBtns_'+npcId+' .chat-topic-btn');
    btns.forEach(function(b){b.style.borderColor='rgba(52,152,219,0.2)';b.style.color='#8a7a5a';});
    var sel=document.querySelector('#chatTopicBtns_'+npcId+' .chat-topic-btn[data-idx="'+idx+'"]');
    if(sel){sel.style.borderColor='#e2b714';sel.style.color='#e2b714';}
}
function questClaim(questId,npcId,name){
    var fd=new FormData();fd.append('action','claim');fd.append('quest_id',questId);
    fetch('/api/action_quest.php',{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(data){
        if(data.ok&&data.money)updateMapMoney(data.money);
        loadChatModal(npcId,name);
    });
}

document.addEventListener('click',function(e){
    var a=e.target.closest('[data-type="npc"]');
    if(a){
        e.preventDefault();
        var n=a.dataset.name,d=a.dataset.dialog,t=a.dataset.npcType,
            act=a.dataset.action,icon=a.dataset.icon,color=a.dataset.color,url=a.dataset.url;
        var npcId=parseInt(a.dataset.npcId)||0;
        var bgMap={talk:'rgba(52,152,219,0.15)',shop:'rgba(226,183,20,0.12)',
            craft:'rgba(230,126,34,0.12)',quest:'rgba(39,174,96,0.15)',danger:'rgba(231,76,60,0.12)',bank:'rgba(39,174,96,0.15)'};
        var bg=bgMap[t]||bgMap.talk;
        var html='<div class="modal-header">'
            +'<div class="modal-avatar" style="background:'+bg+';border:2px solid '+color+'">'+icon+'</div>'
            +'<div><div class="modal-title" style="color:'+color+'">'+n+'</div>'
            +'<div class="modal-subtitle">'+act+'</div></div></div>'
            +'<div class="modal-body" id="npcModalBody">';
        if(d){html+='<div class="modal-dialog">'+d+'</div>';}
        html+='<div id="npcQuestArea"></div></div>'
            +'<div class="modal-footer">'
            +'<button class="modal-btn modal-btn-primary" onclick="npcAction('+npcId+',\''+t+'\',\''+n.replace(/'/g,"\\'")+'\',\''+act+'\')">'+act+'</button>'
            +'<a href="javascript:closeModal()" class="modal-btn modal-btn-close">关闭</a>'
            +'</div>';
        openModal(html);
        if(npcId>0){showQuestBtn(npcId,a.dataset.quests);}
        return;
    }
    var b=e.target.closest('[data-type="monster"]');
    if(b){
        e.preventDefault();
        var n=b.dataset.name,hp=b.dataset.hp,atk=b.dataset.atk,def=b.dataset.def,
            exp=b.dataset.exp,money=b.dataset.money,desc=b.dataset.desc,
            danger=b.dataset.danger,dc=b.dataset.dangerColor,url=b.dataset.url;
        var html='<div class="modal-header">'
            +'<div class="modal-avatar" style="background:rgba(231,76,60,0.12);border:2px solid '+dc+'">👹</div>'
            +'<div><div class="modal-title" style="color:'+dc+'">'+n+'</div>'
            +'<div class="modal-subtitle" style="color:'+dc+'">'+danger+'</div></div></div>'
            +'<div class="modal-body">';
        if(desc){html+='<div class="modal-dialog">'+desc+'</div>';}
        html+='<div class="modal-stats">'
            +'<div class="modal-stat"><span class="modal-stat-label">❤️ 生命</span><span class="modal-stat-val">'+hp+'</span></div>'
            +'<div class="modal-stat"><span class="modal-stat-label">⚔️ 攻击</span><span class="modal-stat-val">'+atk+'</span></div>'
            +'<div class="modal-stat"><span class="modal-stat-label">🛡️ 防御</span><span class="modal-stat-val">'+def+'</span></div>'
            +'<div class="modal-stat"><span class="modal-stat-label">✨ 经验</span><span class="modal-stat-val">'+exp+'</span></div>'
            +'<div class="modal-stat"><span class="modal-stat-label">💰 金币</span><span class="modal-stat-val">'+money+'</span></div>'
            +'</div></div>'
            +'<div class="modal-footer">'
            +'<a href="'+url+'" class="modal-btn modal-btn-danger">⚔️ 战斗</a>'
            +'<a href="javascript:closeModal()" class="modal-btn modal-btn-close">关闭</a>'
            +'</div>';
        openModal(html);
        return;
    }
});
</script>


<?php renderFooter(); ?>
