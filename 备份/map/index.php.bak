           data-npc-id="<?php echo $pn['id']; ?>"
           data-quests="<?php echo e($npcQuestCache[$pn['id']] ?? '[]'); ?>">

                <div class="npc-avatar <?php echo $npcType; ?>"><?php echo $npcIcon; ?></div>
